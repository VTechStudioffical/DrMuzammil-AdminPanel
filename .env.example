# EmailJS Environment Variables

# Get these from https://dashboard.emailjs.com/admin/account
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here

# Service ID from EmailJS Admin → Email Services
VITE_EMAILJS_SERVICE_ID=service_mediclick

# Template ID from EmailJS Admin → Email Templates
VITE_EMAILJS_TEMPLATE_ID=template_appointment_confirmed